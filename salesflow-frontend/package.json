{
  "name": "salesflow-frontend",
  "version": "0.0.0",
  "scripts": {
    "dev": "ng serve --configuration=development --proxy-config proxy.conf.json --open",
    "start": "npm run dev",
    "build": "ng build --configuration=production",
    "build:dev": "ng build --configuration=development",
    "preview": "npx serve dist/salesflow-frontend/browser -p 4201",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,html,css,json}\""
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.1.0",
    "@angular/cdk": "^20.1.0",
    "@angular/common": "^20.1.0",
    "@angular/compiler": "^20.1.0",
    "@angular/core": "^20.1.0",
    "@angular/forms": "^20.1.0",
    "@angular/platform-browser": "^20.1.0",
    "@angular/router": "^20.1.0",
    "@ng-icons/core": "^32.0.0",
    "@ng-icons/heroicons": "^32.0.0",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "ng2-charts": "^8.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.1.0",
    "@angular/cli": "^20.1.0",
    "@angular/compiler-cli": "^20.1.0",
    "@types/jasmine": "~5.1.0",
    "autoprefixer": "^10.5.0",
    "jasmine-core": "~5.8.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2"
  }
}
